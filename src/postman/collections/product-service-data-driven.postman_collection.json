        {
          "name": "GET /products [smoke test]",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Smoke test — dùng token hợp lệ (sinh động)",
                  "const now = new Date().toISOString();",
                  "pm.request.headers.upsert({",
                  "    key: \"Authorization\",",
                  "    value: `Bearer ${now}`",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"[SMOKE] Server đang chạy — status 200\", () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Response là array sản phẩm\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an(\"array\");",
                  "    pm.expect(body.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{validToken}}",
                "description": "Override bởi Pre-request Script"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Smoke test — kiểm tra Provider service đang hoạt động. Chạy trước tất cả test."
          }
        }
