                      "});",
                      "",
                      "pm.test('Tra ve dung product seed 09', function () {",
                      "    const p = pm.response.json();",
                      "    pm.expect(p.id).to.eql('09');",
                      "    pm.expect(p.type).to.eql('CREDIT_CARD');",
                      "    pm.expect(p.name).to.eql('Gem Visa');",
                      "    pm.expect(p.version).to.eql('v1');",
