%% BVA Principles 3-Point Boundary
%% File: bva_principles.mmd
flowchart TD
    subgraph Lower ["Biên dưới (Lower Boundary)"]
        min_minus_1["min - 1 <br> (Invalid)"] --- min["min <br> (Valid)"] --- min_plus_1["min + 1 <br> (Valid)"]
    end
    subgraph Upper ["Biên trên (Upper Boundary)"]
        max_minus_1["max - 1 <br> (Valid)"] --- max["max <br> (Valid)"] --- max_plus_1["max + 1 <br> (Invalid)"]
    end
    Lower -.-> Upper
    
    style min_minus_1 fill:#FFC7CE,stroke:#9C0006,stroke-width:1px
    style min fill:#C6EFCE,stroke:#006100,stroke-width:2px
    style min_plus_1 fill:#C6EFCE,stroke:#006100,stroke-width:1px
    style max_minus_1 fill:#C6EFCE,stroke:#006100,stroke-width:1px
    style max fill:#C6EFCE,stroke:#006100,stroke-width:2px
    style max_plus_1 fill:#FFC7CE,stroke:#9C0006,stroke-width:1px
